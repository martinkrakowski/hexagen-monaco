{
  "name": "@hexagen/arch-linter",
  "version": "0.1.0",
  "private": true,
  "description": "HexaGen architecture linter, manifest validation, and sync engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "sync": "yarn workspace @hexagen/sync sync",
    "lint:arch": "node dist/index.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "js-yaml": "3.14.1",
    "lodash": "^4.17.21",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.7",
    "@types/node": "^20.12.7",
    "typescript": "^5.5.3"
  }
}
