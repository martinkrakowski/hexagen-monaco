{
  "name": "@hexagen/arch-linter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "tsx src/sync.ts",
    "sync:quiet": "tsx src/sync.ts --quiet",
    "sync:force": "tsx src/sync.ts --force",
    "sync:dry": "tsx src/sync.ts --dry-run",
    "sync:strict": "tsx src/sync.ts --strict",
    "build": "tsc --build",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.7",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
