{
  "compilerOptions": {
    "target": "es2021",
    "lib": ["es2021", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "baseUrl": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "declaration": true,
    "emitDeclarationOnly": true, // Emit only .d.ts (no .js during typecheck/build if not needed)
    "paths": {
      "@hexagen/project-configuration": [
        "packages/project-configuration/src/index.ts"
      ],
      "@hexagen/project-configuration/*": [
        "packages/project-configuration/src/*"
      ],
      "@hexagen/shared": ["packages/shared/src/index.ts"],
      "@hexagen/shared/*": ["packages/shared/src/*"],
      "@hexagen/messaging": ["packages/messaging/src/index.ts"],
      "@hexagen/messaging/*": ["packages/messaging/src/*"],
      "@hexagen/*": ["packages/*/src"],
      "@/*": ["apps/web/src/*"]
    }
  },
  "include": [],
  "exclude": ["node_modules", "dist", ".next"]
}
