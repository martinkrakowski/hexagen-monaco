{
  "compilerOptions": {
    "target": "es2021",
    "lib": ["es2021", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "baseUrl": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "declaration": true,
    "emitDeclarationOnly": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@hexagen/project-configuration": [
        "packages/project-configuration/src/index.ts"
      ],
      "@hexagen/project-configuration/*": [
        "packages/project-configuration/src/*"
      ],
      "@hexagen/shared": ["packages/shared/src/index.ts"],
      "@hexagen/shared/*": ["packages/shared/src/*"],
      "@hexagen/messaging": ["packages/messaging/src/index.ts"],
      "@hexagen/messaging/*": ["packages/messaging/src/*"],
      "@hexagen/*": ["packages/*/src"],
      "@/*": [
        "apps/web/src/*",
        "apps/web/app/*" // covers app/page.tsx, app/layout.tsx, app/api/*, etc.
      ]
    }
  },
  "include": [],
  "exclude": ["node_modules", "dist", ".next"]
}
