{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowImportingTsExtensions": true, // now allowed because emitDeclarationOnly is true
    "noEmit": false, // keep false for .d.ts output
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["./apps/web/app/*"],
      "@hexagen/project-configuration/*": [
        "./packages/project-configuration/src/*"
      ],
      "@hexagen/project-generation/*": ["./packages/project-generation/src/*"],
      "@hexagen/wizard-orchestration/*": [
        "./packages/wizard-orchestration/src/*"
      ],
      "@hexagen/shared/*": ["./packages/shared/src/*"]
    }
  }
}
