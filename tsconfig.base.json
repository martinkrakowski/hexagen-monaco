{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/web/app/*"],
      "@hexagen/project-configuration/*": [
        "./packages/project-configuration/src/*"
      ],
      "@hexagen/project-generation/*": ["./packages/project-generation/src/*"],
      "@hexagen/wizard-orchestration/*": [
        "./packages/wizard-orchestration/src/*"
      ],
      "@hexagen/shared/*": ["./packages/shared/src/*"]
    }
  }
}
