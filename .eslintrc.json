{
  "root": true,
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "turbo",
    "prettier"
  ],
  "parser": "@typescript-eslint/parser",
  "plugins": [
    "@typescript-eslint",
    "import"
  ],
  "rules": {
    "no-console": "warn",
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": [
              "@hexagen/*/*",
              "!@hexagen/shared/*"
            ],
            "message": "Cross-package imports must be done via the barrel file. Only deep imports from `shared` are allowed."
          }
        ]
      }
    ]
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "**/*.js"
  ]
}