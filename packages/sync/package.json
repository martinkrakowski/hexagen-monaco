{
  "name": "@hexagen/sync",
  "version": "0.1.0",
  "private": true,
  "description": "HexaGen monorepo sync tool – enforces structure, generates stubs, runs arch-linter",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "node dist/index.js"
  },
  "dependencies": {
    "@hexagen/arch-linter": "workspace:*",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.1",
    "ts-morph": "^22.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  },
  "bin": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
