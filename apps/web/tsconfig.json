{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "references": [
    {
      "path": "../../packages/project-generation"
    },
    {
      "path": "../../packages/project-configuration"
    },
    {
      "path": "../../packages/wizard-orchestration"
    },
    {
      "path": "../../packages/monaco-orchestration"
    }
  ],
  "paths": {
    "monaco-editor": ["./node_modules/monaco-editor"]
  },
  "exclude": ["node_modules"]
}
