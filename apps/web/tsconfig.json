{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "references": [
    {
      "path": "../../packages/project-generation"
    },
    {
      "path": "../../packages/project-configuration"
    },
    {
      "path": "../../packages/wizard-orchestration"
    }
  ],
  "exclude": [
    "node_modules"
  ]
}
