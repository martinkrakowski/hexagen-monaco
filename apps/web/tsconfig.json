{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "resolveJsonModule": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/*"], // ← fix: points to app/
      "monaco-editor": ["./node_modules/monaco-editor"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "references": [
    {
      "path": "../../packages/project-generation"
    },
    {
      "path": "../../packages/project-configuration"
    },
    {
      "path": "../../packages/wizard-orchestration"
    },
    {
      "path": "../../packages/monaco-orchestration"
    },
    {
      "path": "../../packages/web-driver"
    },
    { "path": "../../packages/shared" }
  ],
  "exclude": ["node_modules"]
}
